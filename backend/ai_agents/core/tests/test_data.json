{
  "test_data_version": "1.0.0",
  "description": "全面的测试数据集",
  "normal_scenarios": [
    {
      "id": "normal-001",
      "name": "标准网站扫描",
      "target": "http://example.com",
      "description": "标准的HTTP网站扫描测试",
      "expected_tasks": [
        "baseinfo",
        "portscan",
        "waf_detect",
        "cdn_detect",
        "cms_identify"
      ]
    },
    {
      "id": "normal-002",
      "name": "HTTPS网站扫描",
      "target": "https://secure.example.com",
      "description": "HTTPS加密网站扫描测试",
      "expected_tasks": [
        "baseinfo",
        "waf_detect",
        "cdn_detect",
        "cms_identify"
      ]
    },
    {
      "id": "normal-003",
      "name": "带端口网站扫描",
      "target": "http://example.com:8080",
      "description": "带自定义端口的网站扫描",
      "expected_tasks": [
        "baseinfo",
        "portscan",
        "waf_detect"
      ]
    },
    {
      "id": "normal-004",
      "name": "子域名扫描",
      "target": "http://subdomain.example.com",
      "description": "子域名网站扫描测试",
      "expected_tasks": [
        "baseinfo",
        "subdomain_scan",
        "cms_identify"
      ]
    },
    {
      "id": "normal-005",
      "name": "IP地址扫描",
      "target": "http://192.168.1.1",
      "description": "直接IP地址扫描测试",
      "expected_tasks": [
        "baseinfo",
        "portscan",
        "iplocating"
      ]
    }
  ],
  "boundary_conditions": [
    {
      "id": "boundary-001",
      "name": "空目标URL",
      "target": "",
      "description": "空字符串作为目标URL",
      "expected_behavior": "应该抛出验证错误或使用默认目标"
    },
    {
      "id": "boundary-002",
      "name": "超长URL",
      "target": "http://example.com/aaaaaaaaaaaaaaaaaaaaa",
      "description": "超过20字符的超长URL",
      "expected_behavior": "应该能够正确处理或截断URL"
    },
    {
      "id": "boundary-003",
      "name": "特殊字符URL",
      "target": "http://example.com/测试!@#$%^&*()",
      "description": "包含特殊字符的URL",
      "expected_behavior": "应该能够正确编码和处理特殊字符"
    },
    {
      "id": "boundary-004",
      "name": "非常短的任务ID",
      "target": "http://example.com",
      "task_id": "1",
      "description": "只有1个字符的任务ID",
      "expected_behavior": "应该能够正常处理短任务ID"
    },
    {
      "id": "boundary-005",
      "name": "超长任务ID",
      "target": "http://example.com",
      "task_id": "task-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "description": "超过50字符的任务ID",
      "expected_behavior": "应该能够正常处理长任务ID"
    },
    {
      "id": "boundary-006",
      "name": "零工具执行",
      "target": "http://example.com",
      "tasks": [],
      "description": "不执行任何工具",
      "expected_behavior": "应该直接跳过到分析阶段"
    },
    {
      "id": "boundary-007",
      "name": "大量工具执行",
      "target": "http://example.com",
      "tasks": ["baseinfo", "portscan", "waf_detect", "cdn_detect", "cms_identify", "infoleak_scan", "subdomain_scan", "webside_scan", "webweight_scan", "iplocating", "loginfo", "randheader"],
      "description": "执行所有可用工具",
      "expected_behavior": "应该能够依次执行所有工具"
    }
  ],
  "error_scenarios": [
    {
      "id": "error-001",
      "name": "无效协议",
      "target": "ftp://example.com",
      "description": "使用不支持的FTP协议",
      "expected_error": "Protocol not supported"
    },
    {
      "id": "error-002",
      "name": "不存在的域名",
      "target": "http://this-domain-does-not-exist-12345.com",
      "description": "不存在的域名",
      "expected_error": "DNS resolution failed"
    },
    {
      "id": "error-003",
      "name": "连接被拒绝",
      "target": "http://127.0.0.1:9999",
      "description": "连接到不存在的端口",
      "expected_error": "Connection refused"
    },
    {
      "id": "error-004",
      "name": "超时目标",
      "target": "http://10.255.255.1",
      "description": "会导致超时的私有IP",
      "expected_error": "Connection timeout"
    },
    {
      "id": "error-005",
      "name": "HTTP 404错误",
      "target": "http://example.com/this-page-does-not-exist",
      "description": "返回404的URL",
      "expected_error": "HTTP 404 Not Found"
    },
    {
      "id": "error-006",
      "name": "HTTP 500错误",
      "target": "http://httpstat.us/500",
      "description": "返回500错误的服务",
      "expected_error": "HTTP 500 Internal Server Error"
    },
    {
      "id": "error-007",
      "name": "无效IP格式",
      "target": "http://999.999.999.999",
      "description": "无效的IP地址格式",
      "expected_error": "Invalid IP address"
    },
    {
      "id": "error-008",
      "name": "无网络连接",
      "target": "http://example.com",
      "description": "模拟无网络连接场景",
      "expected_error": "Network unreachable"
    }
  ],
  "cve_test_cases": [
    {
      "id": "cve-001",
      "cve_id": "CVE-2017-12149",
      "name": "JBoss JMXInvokerServlet 反序列化",
      "description": "JBoss反序列化漏洞测试",
      "target": "http://jboss-server.example.com",
      "severity": "critical"
    },
    {
      "id": "cve-002",
      "cve_id": "CVE-2018-7600",
      "name": "Drupal远程代码执行",
      "description": "Drupal核心远程代码执行漏洞",
      "target": "http://drupal-server.example.com",
      "severity": "critical"
    },
    {
      "id": "cve-003",
      "cve_id": "CVE-2020-10199",
      "name": "Nexus Repository Manager远程代码执行",
      "description": "Nexus仓库管理系统漏洞",
      "target": "http://nexus-server.example.com",
      "severity": "critical"
    },
    {
      "id": "cve-004",
      "cve_id": "CVE-2022-22965",
      "name": "Spring4Shell",
      "description": "Spring框架远程代码执行漏洞",
      "target": "http://spring-app.example.com",
      "severity": "critical"
    },
    {
      "id": "cve-005",
      "cve_id": "CVE-2018-2628",
      "name": "WebLogic反序列化",
      "description": "WebLogic Server反序列化漏洞",
      "target": "http://weblogic-server.example.com",
      "severity": "critical"
    },
    {
      "id": "cve-006",
      "cve_id": "CVE-INVALID-001",
      "name": "无效CVE编号",
      "description": "测试无效CVE编号的处理",
      "target": "http://example.com",
      "expected_behavior": "应该返回CVE不存在的错误"
    }
  ],
  "stress_test_targets": [
    {
      "id": "stress-001",
      "name": "并发扫描测试",
      "targets": [
        "http://example1.com",
        "http://example2.com",
        "http://example3.com",
        "http://example4.com",
        "http://example5.com"
      ],
      "concurrent_users": 5,
      "description": "5个并发用户同时扫描"
    },
    {
      "id": "stress-002",
      "name": "高并发扫描测试",
      "targets": ["http://example.com"],
      "concurrent_users": 100,
      "description": "100个并发用户扫描同一目标"
    },
    {
      "id": "stress-003",
      "name": "长时间稳定性测试",
      "targets": ["http://example.com"],
      "duration_hours": 24,
      "description": "24小时连续扫描测试"
    }
  ],
  "performance_baseline": {
    "state_creation": {
      "max_acceptable_ms": 10,
      "target_ms": 5
    },
    "graph_creation": {
      "max_acceptable_ms": 100,
      "target_ms": 50
    },
    "node_execution": {
      "max_acceptable_seconds": 30,
      "target_seconds": 10
    },
    "complete_workflow": {
      "max_acceptable_seconds": 300,
      "target_seconds": 120
    }
  }
}
