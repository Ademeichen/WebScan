{
    "test_targets": [
        {
            "id": "target_001",
            "name": "Test Target - Normal",
            "url": "https://www.baidu.com",
            "description": "正常可访问的测试目标",
            "expected_result": "accessible",
            "timeout": 30
        },
        {
            "id": "target_002",
            "name": "Test Target - Vulnerable",
            "url": "http://testphp.vulnweb.com",
            "description": "模拟存在漏洞的测试目标",
            "expected_result": "vulnerable",
            "timeout": 30
        },
        {
            "id": "target_003",
            "name": "Test Target - Invalid",
            "url": "http://invalid.example.local",
            "description": "无效的测试目标",
            "expected_result": "error",
            "timeout": 10
        },
        {
            "id": "target_004",
            "name": "Test Target - Timeout",
            "url": "http://timeout.example.local",
            "description": "会超时的测试目标",
            "expected_result": "timeout",
            "timeout": 5
        },
        {
            "id": "target_005",
            "name": "Test Target - HTTPS",
            "url": "https://github.com",
            "description": "HTTPS测试目标",
            "expected_result": "accessible",
            "timeout": 30
        }
    ],
    "execution_config": {
        "default_timeout": 60,
        "max_retries": 3,
        "retry_delay": 2.0,
        "max_concurrent": 5,
        "enable_sandbox": true,
        "max_memory_mb": 512,
        "max_cpu_percent": 80.0
    },
    "test_scenarios": [
        {
            "name": "single_execution",
            "description": "单个POC执行测试",
            "poc_id": "test-001",
            "target_ids": ["target_001"]
        },
        {
            "name": "batch_execution",
            "description": "批量POC执行测试",
            "poc_ids": ["test-001", "test-002"],
            "target_ids": ["target_001", "target_002"]
        },
        {
            "name": "timeout_handling",
            "description": "超时处理测试",
            "poc_id": "test-003",
            "target_ids": ["target_004"]
        },
        {
            "name": "error_handling",
            "description": "异常处理测试",
            "poc_id": "test-004",
            "target_ids": ["target_001"]
        }
    ]
}
